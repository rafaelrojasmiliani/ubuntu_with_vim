" Context helpers
" ============================================================================

function! s:add_extra_commit_context(context, comment_char) abort
  let l:extra = get(g:, 'fugitive_commit_extra_context', [])

  if empty(l:extra)
    return
  endif

  call add(a:context, a:comment_char . ' Additional project context')

  for l:line in l:extra
    call add(a:context, a:comment_char . ' - ' . l:line)
  endfor

  call add(a:context, a:comment_char)
endfunction

function! s:staged_diff_context(comment_char) abort
  let l:context = []

  let l:names = s:git_lines(['diff', ' --cached', '--name-status',' --'])
  let l:stat = s:git_lines(['diff', '--cached', '--stat', '--'])


  let l:diff = s:git_lines([
        \ 'diff',
        \ '--cached',
        \ '--no-ext-diff',
        \ '--no-color',
        \ '--unified=' . string(g:fugitive_commit_diff_unified_context),
        \ '--',
        \ ])

  if empty(l:names) && empty(l:stat) && empty(l:diff)
    return [
          \ a:comment_char . ' Staged diff',
          \ a:comment_char . ' - No staged changes detected.',
          \ ]
  endif

  call extend(l:context, [
        \ a:comment_char . ' Staged files',
        \ ])

  call extend(l:context, s:comment_lines(l:names, a:comment_char))

  call extend(l:context, [
        \ a:comment_char,
        \ a:comment_char . ' Diff stat',
        \ ])

  call extend(l:context, s:comment_lines(l:stat, a:comment_char))

  call extend(l:context, [
        \ a:comment_char,
        \ a:comment_char . ' Staged diff',
        \ ])

  let l:max = get(g:, 'fugitive_commit_diff_max_lines', 300)

  if l:max <= 0
    let l:diff = ['[diff omitted because g:fugitive_commit_diff_max_lines <= 0]']
  elseif len(l:diff) > l:max
    let l:diff = l:diff[:l:max - 1]
    call add(l:diff, '')
    call add(l:diff, '[diff truncated at ' . string(l:max) . ' lines]')
  endif

  call extend(l:context, s:comment_lines(l:diff, a:comment_char))

  return l:context
endfunction

function! s:comment_lines(lines, comment_char) abort
  let l:commented = []

  for l:line in a:lines
    if l:line ==# ''
      call add(l:commented, a:comment_char)
    else
      call add(l:commented, a:comment_char . ' ' . l:line)
    endif
  endfor

  return l:commented
endfunction


" ============================================================================
" Git helpers
" ============================================================================
function! s:git_lines(argv) abort
  if exists('*FugitiveExecute') && exists('*FugitiveGitDir')
    let l:git_dir = FugitiveGitDir()

    if !empty(l:git_dir)
      let l:result = FugitiveExecute(a:argv, l:git_dir)

      if type(l:result) == type({}) && get(l:result, 'exit_status', 1) == 0
        return get(l:result, 'stdout', [])
      endif

      " Optional debugging:
      " echom 'git argv: ' . string(a:argv)
      " echom 'git exit: ' . string(get(l:result, 'exit_status', 'missing'))
      " echom 'git stderr: ' . string(get(l:result, 'stderr', []))

      return []
    endif
  endif

  let l:root = systemlist('git rev-parse --show-toplevel')

  if v:shell_error || empty(l:root)
    return []
  endif

  let l:cmd = ['git', '-C', l:root[0]] + a:argv
  let l:out = systemlist(l:cmd)

  if v:shell_error
    return []
  endif

  return l:out
endfunction


function! s:commit_comment_char() abort
  let l:out = systemlist('git config --get core.commentChar')

  if v:shell_error || empty(l:out) || l:out[0] ==# '' || l:out[0] ==# 'auto'
    return '#'
  endif

  return l:out[0]
endfunction


