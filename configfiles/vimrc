" ============================================================================
" Cursor Agent Management
" ===========================================================================

function! s:CursorAgentCleanList() abort
  let g:cursor_agent_buffers = filter(
        \ copy(g:cursor_agent_buffers),
        \ 'bufexists(v:val)'
        \ )
endfunction

function! CursorAgentNew() abort
  botright split
  terminal cursor-agent

  let b:is_cursor_agent = 1
  let b:cursor_agent_index = len(g:cursor_agent_buffers)

  call add(g:cursor_agent_buffers, bufnr('%'))

  execute 'file cursor-agent://' . b:cursor_agent_index
  echo 'Created cursor-agent #' . b:cursor_agent_index
endfunction

function! CursorAgentList() abort
  call s:CursorAgentCleanList()

  if empty(g:cursor_agent_buffers)
    echo 'No cursor-agent buffers'
    return
  endif

  echo 'Cursor agents:'

  for i in range(0, min([9, len(g:cursor_agent_buffers) - 1]))
    let l:bufnr = g:cursor_agent_buffers[i]
    let l:name = bufname(l:bufnr)

    if bufwinnr(l:bufnr) != -1
      let l:state = '[open]'
    else
      let l:state = '[hidden]'
    endif

    echo printf('%d: buffer %d %s %s', i, l:bufnr, l:state, l:name)
  endfor
endfunction

function! CursorAgentOpen(index) abort
  call s:CursorAgentCleanList()

  if a:index < 0 || a:index >= len(g:cursor_agent_buffers) || a:index > 9
    echoerr 'No cursor-agent at index ' . a:index
    return
  endif

  let l:bufnr = g:cursor_agent_buffers[a:index]

  if !bufexists(l:bufnr)
    echoerr 'Cursor-agent buffer no longer exists: ' . a:index
    return
  endif

  botright split
  execute 'buffer' l:bufnr
endfunction

command! CursorAgentNew call CursorAgentNew()
command! CursorAgentList call CursorAgentList()
command! -nargs=1 CursorAgentOpen call CursorAgentOpen(<args>)

