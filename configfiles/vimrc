function! s:difftastic_restore_env(old_env) abort
  let $DFT_DISPLAY = get(a:old_env, 'display', '')
  let $DFT_COLOR = get(a:old_env, 'color', '')
  let $DFT_SYNTAX_HIGHLIGHT = get(a:old_env, 'syntax', '')
  let $DFT_CONTEXT = get(a:old_env, 'context', '')
  let $DFT_WIDTH = get(a:old_env, 'width', '')
  let $DFT_UNSTABLE = get(a:old_env, 'unstable', '')
endfunction

function! s:difftastic_run_staged_diff() abort
  call s:difftastic_debug('starting difftastic staged diff')

  if !get(g:, 'fugitive_commit_include_difftastic', 1)
    call s:difftastic_debug('disabled by g:fugitive_commit_include_difftastic')
    return {'exit_status': -1, 'stdout': [], 'stderr': ['difftastic integration disabled']}
  endif

  call s:difftastic_debug('executable("difft") = ' . string(executable('difft')))

  if !executable('difft')
    return {'exit_status': -1, 'stdout': [], 'stderr': ['difft executable not found in PATH']}
  endif

  call s:difftastic_debug('exists("*FugitiveExecute") = ' . string(exists('*FugitiveExecute')))
  call s:difftastic_debug('exists("*FugitiveGitDir") = ' . string(exists('*FugitiveGitDir')))

  if !exists('*FugitiveExecute') || !exists('*FugitiveGitDir')
    return {'exit_status': -1, 'stdout': [], 'stderr': ['FugitiveExecute or FugitiveGitDir unavailable']}
  endif

  let l:git_dir = FugitiveGitDir()
  call s:difftastic_debug('FugitiveGitDir() = ' . string(l:git_dir))

  if empty(l:git_dir)
    return {'exit_status': -1, 'stdout': [], 'stderr': ['empty FugitiveGitDir()']}
  endif

  let l:old_env = {
        \ 'display': $DFT_DISPLAY,
        \ 'color': $DFT_COLOR,
        \ 'syntax': $DFT_SYNTAX_HIGHLIGHT,
        \ 'context': $DFT_CONTEXT,
        \ 'width': $DFT_WIDTH,
        \ 'unstable': $DFT_UNSTABLE,
        \ }

  let l:display = get(g:, 'fugitive_commit_difftastic_display', 'json')

  let l:argv = [
        \ '-c',
        \ 'diff.external=difft',
        \ 'diff',
        \ '--cached',
        \ ]

  call s:difftastic_debug('DFT_DISPLAY = ' . string(l:display))
  call s:difftastic_debug('argv = ' . string(l:argv))

  try
    let $DFT_DISPLAY = l:display
    let $DFT_COLOR = 'never'
    let $DFT_SYNTAX_HIGHLIGHT = 'off'
    let $DFT_CONTEXT = string(get(g:, 'fugitive_commit_difftastic_context', 2))
    let $DFT_WIDTH = '120'

    " Required by difftastic for --display=json / DFT_DISPLAY=json.
    if l:display ==# 'json'
      let $DFT_UNSTABLE = 'yes'
    endif

    call s:difftastic_debug('DFT_UNSTABLE = ' . string($DFT_UNSTABLE))

    let l:result = FugitiveExecute(l:argv, l:git_dir)
  finally
    call s:difftastic_restore_env(l:old_env)
  endtry

  call s:difftastic_debug('result type = ' . string(type(l:result)))

  if type(l:result) != type({})
    return {'exit_status': -1, 'stdout': [], 'stderr': ['FugitiveExecute returned non-dictionary result']}
  endif

  call s:difftastic_debug('exit_status = ' . string(get(l:result, 'exit_status', 'missing')))
  call s:difftastic_debug('stdout lines = ' . string(len(get(l:result, 'stdout', []))))
  call s:difftastic_debug('stderr lines = ' . string(len(get(l:result, 'stderr', []))))

  if !empty(get(l:result, 'stderr', []))
    call s:difftastic_debug('stderr[0] = ' . string(get(l:result.stderr, 0, '')))
  endif

  if !empty(get(l:result, 'stdout', []))
    call s:difftastic_debug('stdout[0] = ' . string(get(l:result.stdout, 0, '')))
  endif

  return l:result
endfunction


function! s:difftastic_decode_json_debug(lines) abort
  let l:files = []

  call s:difftastic_debug('attempting JSON decode of ' . string(len(a:lines)) . ' stdout lines')

  for l:line in a:lines
    if empty(trim(l:line))
      continue
    endif

    try
      let l:decoded = json_decode(l:line)

      if type(l:decoded) == type([])
        call s:difftastic_debug('decoded JSON array with ' . string(len(l:decoded)) . ' files')
        call extend(l:files, l:decoded)
      elseif type(l:decoded) == type({})
        call s:difftastic_debug('decoded JSON object for path = ' . string(get(l:decoded, 'path', '[no path]')))
        call add(l:files, l:decoded)
      else
        call s:difftastic_debug('decoded JSON, unexpected type = ' . string(type(l:decoded)))
      endif
    catch
      call s:difftastic_debug('JSON decode failed for line prefix = ' . string(strpart(l:line, 0, 120)))
    endtry
  endfor

  call s:difftastic_debug('decoded file count = ' . string(len(l:files)))

  return l:files
endfunction

function! s:difftastic_json_summary_lines(files) abort
  let l:lines = []

  let l:max_entries = get(g:, 'fugitive_commit_difftastic_max_entries_per_file', 80)

  for l:file in a:files
    let l:path = get(l:file, 'path', '[unknown path]')
    let l:language = get(l:file, 'language', 'unknown')
    let l:status = get(l:file, 'status', 'unknown')
    let l:chunks = get(l:file, 'chunks', [])

    call add(l:lines, 'File: ' . l:path . ' (' . l:language . ', ' . l:status . ')')
    call add(l:lines, '- chunks: ' . string(len(l:chunks)))

    let l:entry_count = 0
    let l:chunk_index = 0

    for l:chunk in l:chunks
      let l:chunk_index += 1
      call add(l:lines, '- chunk ' . string(l:chunk_index) . ':')

      for l:entry in l:chunk
        if l:entry_count >= l:max_entries
          call add(l:lines, '  - [semantic entries truncated at ' . string(l:max_entries) . ']')
          break
        endif

        let l:lhs = get(l:entry, 'lhs', {})
        let l:rhs = get(l:entry, 'rhs', {})

        let l:old_line = s:difftastic_side_line_number(l:lhs)
        let l:new_line = s:difftastic_side_line_number(l:rhs)

        let l:old_text = s:difftastic_side_changed_text(l:lhs)
        let l:new_text = s:difftastic_side_changed_text(l:rhs)

        if empty(l:old_text) && empty(l:new_text)
          continue
        endif

        if !empty(l:old_text)
          call add(l:lines, '  - removed @ old line ' . l:old_line . ': ' . l:old_text)
        endif

        if !empty(l:new_text)
          call add(l:lines, '  - added   @ new line ' . l:new_line . ': ' . l:new_text)
        endif

        let l:entry_count += 1
      endfor
    endfor

    call add(l:lines, '')
  endfor

  return l:lines
endfunction
function! s:difftastic_side_line_number(side) abort
  if type(a:side) != type({})
    return '?'
  endif

  if !has_key(a:side, 'line_number')
    return '?'
  endif

  return string(get(a:side, 'line_number'))
endfunction

function! s:difftastic_side_changed_text(side) abort
  if type(a:side) != type({})
    return ''
  endif

  let l:changes = get(a:side, 'changes', [])

  if empty(l:changes)
    return ''
  endif

  let l:parts = []

  for l:change in l:changes
    let l:content = get(l:change, 'content', '')

    " Normalize whitespace, but keep symbolic/code content readable.
    let l:content = substitute(l:content, '\s\+', ' ', 'g')
    let l:content = trim(l:content)

    if !empty(l:content)
      call add(l:parts, l:content)
    endif
  endfor

  let l:text = join(l:parts, ' ')

  return s:difftastic_shorten(l:text, 160)
endfunction

function! s:difftastic_shorten(text, max_len) abort
  if strlen(a:text) <= a:max_len
    return a:text
  endif

  return strpart(a:text, 0, a:max_len - 3) . '...'
endfunction

function! s:difftastic_staged_diff_context(comment_char) abort
  call s:difftastic_debug('s:difftastic_staged_diff_context() called')

  let l:result = s:difftastic_run_staged_diff()

  let l:exit = get(l:result, 'exit_status', -1)
  let l:stdout = get(l:result, 'stdout', [])
  let l:stderr = get(l:result, 'stderr', [])

  let l:context = [
        \ a:comment_char . ' Semantic diff debug',
        \ a:comment_char . ' - display: ' . get(g:, 'fugitive_commit_difftastic_display', 'json'),
        \ a:comment_char . ' - exit_status: ' . string(l:exit),
        \ a:comment_char . ' - stdout lines: ' . string(len(l:stdout)),
        \ a:comment_char . ' - stderr lines: ' . string(len(l:stderr)),
        \ a:comment_char,
        \ ]

    let l:stderr_nonempty = filter(copy(l:stderr), '!empty(trim(v:val))')

    if !empty(l:stderr_nonempty)
      call extend(l:context, s:difftastic_comment_lines(['stderr:'], a:comment_char))
      call extend(l:context, s:difftastic_comment_lines(l:stderr_nonempty[: min([len(l:stderr_nonempty), 20]) - 1], a:comment_char))
      call add(l:context, a:comment_char)
    endif

  if empty(l:stdout)
    call add(l:context, a:comment_char . ' - no difftastic stdout')
    call add(l:context, a:comment_char)
    return l:context
  endif

  if get(g:, 'fugitive_commit_difftastic_display', 'json') ==# 'json'
    let l:files = s:difftastic_decode_json_debug(l:stdout)
    call extend(l:context, s:difftastic_comment_lines(s:difftastic_json_summary_lines(l:files), a:comment_char))
  else
    let l:max = get(g:, 'fugitive_commit_difftastic_max_lines', 250)
    let l:shown = l:stdout

    if l:max > 0 && len(l:shown) > l:max
      let l:shown = l:shown[:l:max - 1]
      call add(l:shown, '[difftastic output truncated at ' . string(l:max) . ' lines]')
    endif

    call extend(l:context, s:difftastic_comment_lines(l:shown, a:comment_char))
  endif

  call add(l:context, a:comment_char)
  return l:context
endfunction

