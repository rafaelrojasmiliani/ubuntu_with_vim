function! s:ctags_diff_context(comment_char) abort
  call s:ctags_debug('ctags_diff_context() called')

  if !get(g:, 'fugitive_commit_include_ctags', 1)
    call s:ctags_debug('disabled by g:fugitive_commit_include_ctags')
    return []
  endif

  let l:ctags = get(g:, 'fugitive_commit_ctags_command', 'ctags')
  call s:ctags_debug('ctags command = ' . string(l:ctags))
  call s:ctags_debug('executable(ctags) = ' . string(executable(l:ctags)))

  if !executable(l:ctags)
    return [
          \ a:comment_char . ' Changed semantic scopes',
          \ a:comment_char . ' - ctags executable "' . l:ctags . '" was not found in PATH.',
          \ a:comment_char,
          \ ]
  endif

  let l:files = s:git_lines([
        \ 'diff',
        \ '--cached',
        \ '--name-only',
        \ '--diff-filter=ACMR',
        \ '--',
        \ ])

  " Important: remove blank paths.
  call filter(l:files, '!empty(trim(v:val))')

  call s:ctags_debug('staged files count = ' . string(len(l:files)))
  call s:ctags_debug('staged files = ' . string(l:files))

  if empty(l:files)
    call s:ctags_debug('No staged files found for ctags context')
    return []
  endif


    let l:context = [
          \ a:comment_char . ' Changed semantic scopes',
          \ a:comment_char . ' - These are staged changes grouped by enclosing symbol.',
          \ a:comment_char . ' - Use this section to identify affected APIs, classes, functions, methods, and file-level changes.',
          \ a:comment_char . ' - Prefer function/method scopes over file names when writing the commit message.',
          \ a:comment_char,
          \ ]

  let l:file_count = 0
  let l:max_files = get(g:, 'fugitive_commit_ctags_max_files', 20)

  for l:path in l:files
    call s:ctags_debug('processing staged file = ' . string(l:path))

    if l:file_count >= l:max_files
      call add(l:context, a:comment_char . ' - [ctags scope context truncated at ' . string(l:max_files) . ' files]')
      call add(l:context, a:comment_char)
      break
    endif

    let l:file_context = s:ctags_file_scope_context(l:path, a:comment_char)

    call s:ctags_debug('file context lines for ' . l:path . ' = ' . string(len(l:file_context)))

    if !empty(l:file_context)
      call extend(l:context, l:file_context)
      let l:file_count += 1
    endif
  endfor

  call s:ctags_debug('ctags context file_count = ' . string(l:file_count))

  if l:file_count == 0
    call s:ctags_debug('No ctags context generated for any staged files')
    return []
  endif

  return l:context
endfunction

function! s:ctags_file_scope_context(path, comment_char) abort
  call s:ctags_debug('ctags_file_scope_context() path = ' . string(a:path))

  if empty(a:path)
    call s:ctags_debug('empty path; returning []')
    return []
  endif

  let l:changed_lines = s:git_changed_new_lines_for_file(a:path)

  call s:ctags_debug('changed new lines for ' . a:path . ' = ' . string(l:changed_lines))

  if empty(l:changed_lines)
    call s:ctags_debug('no changed new lines for ' . a:path . '; returning []')
    return []
  endif

  let l:tags = s:ctags_for_staged_file(a:path)
  let l:tags = s:ctags_for_staged_file(a:path)

  call s:ctags_debug('ctags tags count for ' . a:path . ' = ' . string(len(l:tags)))
  call s:ctags_debug_relevant_tags(a:path, l:tags, l:changed_lines)

  call s:ctags_debug('ctags tags count for ' . a:path . ' = ' . string(len(l:tags)))

  let l:context = [
        \ a:comment_char . ' File: ' . a:path,
        \ ]

  if empty(l:tags)
    call s:ctags_debug('no ctags symbol ranges found for ' . a:path)
    call add(l:context, a:comment_char . ' - changed staged lines: ' . s:join_numbers(l:changed_lines))
    call add(l:context, a:comment_char . ' - no ctags symbol ranges found')
    call add(l:context, a:comment_char)
    return l:context
  endif

  let l:scopes = {}

  for l:line in l:changed_lines
    let l:symbol = s:ctags_best_symbol_for_line(l:tags, l:line)

    if empty(l:symbol)
      let l:key = '[file scope]'
      call s:ctags_debug('line ' . string(l:line) . ' -> file scope')
    else
      let l:key = s:ctags_symbol_label(l:symbol, l:tags, l:line)
      call s:ctags_debug('line ' . string(l:line) . ' -> ' . l:key)
    endif

    if !has_key(l:scopes, l:key)
      let l:scopes[l:key] = []
    endif

    call add(l:scopes[l:key], l:line)
  endfor

  call s:ctags_debug('scope keys for ' . a:path . ' = ' . string(keys(l:scopes)))

  for l:scope in sort(keys(l:scopes))
    let l:lines = uniq(sort(l:scopes[l:scope], 'n'))

    call add(l:context, a:comment_char . ' - ' . l:scope)
    call add(l:context, a:comment_char . '   changed new lines: ' . s:join_numbers(l:lines))
  endfor

  call add(l:context, a:comment_char)

  return l:context
endfunction
function! s:git_changed_new_lines_for_file(path) abort
  call s:ctags_debug('git_changed_new_lines_for_file() path = ' . string(a:path))

  if empty(a:path)
    call s:ctags_debug('empty path; returning []')
    return []
  endif

  let l:patch = s:git_lines_ctags_debug([
        \ 'diff',
        \ '--cached',
        \ '-U0',
        \ '--no-ext-diff',
        \ '--no-color',
        \ '--',
        \ a:path,
        \ ])

  call s:ctags_debug('patch line count for ' . a:path . ' = ' . string(len(l:patch)))

  if empty(l:patch)
    call s:ctags_debug('empty patch for ' . a:path)
    return []
  endif

  call s:ctags_debug('patch first line = ' . string(get(l:patch, 0, '')))
  call s:ctags_debug('patch first hunk = ' . string(s:first_matching_line(l:patch, '^@@ ')))

  let l:changed = []
  let l:in_hunk = 0
  let l:new_lnum = 0

  for l:line in l:patch
    if l:line =~# '^@@ '
      let l:new_spec = matchstr(l:line, '+\d\+\%\(,\d\+\)\?')
      let l:new_start = str2nr(matchstr(l:new_spec, '+\zs\d\+'))

      call s:ctags_debug('hunk header = ' . string(l:line))
      call s:ctags_debug('new spec = ' . string(l:new_spec))
      call s:ctags_debug('new start = ' . string(l:new_start))

      let l:new_lnum = l:new_start
      let l:in_hunk = 1
      continue
    endif

    if !l:in_hunk
      continue
    endif

    if l:line =~# '^+++ ' || l:line =~# '^\\'
      continue
    endif

    let l:first = strpart(l:line, 0, 1)

    if l:first ==# '+'
      call add(l:changed, l:new_lnum)
      call s:ctags_debug('added line -> new line ' . string(l:new_lnum))
      let l:new_lnum += 1
    elseif l:first ==# '-'
      call add(l:changed, max([1, l:new_lnum]))
      call s:ctags_debug('removed line -> anchored to new line ' . string(max([1, l:new_lnum])))
    else
      let l:new_lnum += 1
    endif
  endfor

  let l:changed = uniq(sort(l:changed, 'n'))

  call s:ctags_debug('final changed new lines for ' . a:path . ' = ' . string(l:changed))

  return l:changed
endfunction
function! s:ctags_for_staged_file(path) abort
  let l:content = s:git_lines_ctags_debug(['show', ':' . a:path])

  if empty(l:content)
    call s:ctags_debug('empty staged content for ' . a:path)
    return []
  endif

  let l:ext = fnamemodify(a:path, ':e')
  let l:tmp = tempname()

  if !empty(l:ext)
    let l:tmp .= '.' . l:ext
  endif

  try
    call writefile(l:content, l:tmp)

    let l:ctags = get(g:, 'fugitive_commit_ctags_command', 'ctags')

    " Do NOT use --output-format=json here.
    " This uses normal tags output and asks for line/end/kind fields.
    let l:cmd =
          \ shellescape(l:ctags) .
          \ ' --fields=+neK' .
          \ ' --extras=+q' .
          \ ' -f - ' .
          \ shellescape(l:tmp)

    call s:ctags_debug('ctags cmd = ' . l:cmd)

    let l:out = systemlist(l:cmd)

    call s:ctags_debug('ctags shell_error = ' . string(v:shell_error))
    call s:ctags_debug('ctags output lines = ' . string(len(l:out)))

    if !empty(l:out)
      call s:ctags_debug('ctags output[0] = ' . string(get(l:out, 0, '')))
      call s:ctags_debug('ctags output[1] = ' . string(get(l:out, 1, '')))
      call s:ctags_debug('ctags output[2] = ' . string(get(l:out, 2, '')))
    endif

    if v:shell_error
      call s:ctags_debug('ctags failed for ' . a:path . ': ' . string(l:out))
      return []
    endif

    let l:tags = s:parse_ctags_tagfile_lines(l:out)

    call s:ctags_debug(a:path . ': decoded ' . string(len(l:tags)) . ' tags')

    return l:tags
  finally
    call delete(l:tmp)
  endtry
endfunction


function! s:ctags_best_symbol_for_line(tags, line) abort
  let l:candidates = []

  for l:tag in a:tags
    let l:start = get(l:tag, 'line', 0)
    let l:end = get(l:tag, 'end', l:start)

    if l:start <= a:line && a:line <= l:end
      call add(l:candidates, l:tag)
    endif
  endfor

  if empty(l:candidates)
    return {}
  endif

  call sort(l:candidates, function('s:ctags_compare_symbol_priority'))

  return l:candidates[0]
endfunction
function! s:ctags_symbol_priority(tag) abort
  let l:kind = s:ctags_effective_kind(a:tag)

  if l:kind =~# 'function\|method\|member\|constructor\|destructor\|procedure\|subroutine'
    return 0
  endif

  if l:kind =~# 'class\|struct\|union\|interface\|enum'
    return 1
  endif

  if l:kind =~# 'namespace\|module\|package'
    return 2
  endif

  return 3
endfunction
function! s:ctags_compare_symbol_priority(left, right) abort
  let l:left_priority = s:ctags_symbol_priority(a:left)
  let l:right_priority = s:ctags_symbol_priority(a:right)

  if l:left_priority != l:right_priority
    return l:left_priority - l:right_priority
  endif

  let l:left_size = s:ctags_range_size(a:left)
  let l:right_size = s:ctags_range_size(a:right)

  if l:left_size != l:right_size
    return l:left_size - l:right_size
  endif

  " Prefer qualified names generated by --extras=+q.
  let l:left_qualified = get(a:left, 'name', '') =~# '::' ? 0 : 1
  let l:right_qualified = get(a:right, 'name', '') =~# '::' ? 0 : 1

  if l:left_qualified != l:right_qualified
    return l:left_qualified - l:right_qualified
  endif

  return 0
endfunction

function! s:ctags_kind_priority(kind) abort
  let l:kind = tolower(a:kind)

  if l:kind =~# 'function\|method\|member\|constructor\|destructor\|procedure\|subroutine'
    return 0
  endif

  if l:kind =~# 'class\|struct\|union\|interface\|enum'
    return 1
  endif

  if l:kind =~# 'namespace\|module\|package'
    return 2
  endif

  return 3
endfunction


function! s:ctags_range_size(tag) abort
  let l:start = get(a:tag, 'line', 0)
  let l:end = get(a:tag, 'end', l:start)

  return l:end - l:start
endfunction
function! s:ctags_symbol_label(tag, tags, line) abort
  let l:kind = s:ctags_effective_kind(a:tag)

  if empty(l:kind)
    let l:kind = get(a:tag, 'kind', 'symbol')
  endif

  let l:name = get(a:tag, 'name', '[anonymous]')
  let l:scope = get(a:tag, 'scope', '')

  " If ctags already emitted a qualified name, trust it.
  if l:name =~# '::'
    return l:kind . ' ' . l:name
  endif

  if !empty(l:scope)
    return l:kind . ' ' . l:scope . '::' . l:name
  endif

  let l:parents = s:ctags_parent_symbols(a:tags, a:tag, a:line)

  if empty(l:parents)
    return l:kind . ' ' . l:name
  endif

  let l:names = []

  for l:parent in l:parents
    let l:parent_name = get(l:parent, 'name', '')

    if !empty(l:parent_name) && index(l:names, l:parent_name) < 0
      call add(l:names, l:parent_name)
    endif
  endfor

  call add(l:names, l:name)

  return l:kind . ' ' . join(l:names, '::')
endfunction


function! s:ctags_parent_symbols(tags, child, line) abort
  let l:parents = []

  let l:child_start = get(a:child, 'line', 0)
  let l:child_end = get(a:child, 'end', l:child_start)

  for l:tag in a:tags
    if l:tag is a:child
      continue
    endif

    let l:kind = tolower(get(l:tag, 'kind', ''))

    if l:kind !~# 'namespace\|class\|struct\|union\|interface\|module\|package'
      continue
    endif

    let l:start = get(l:tag, 'line', 0)
    let l:end = get(l:tag, 'end', l:start)

    if l:start <= a:line && a:line <= l:end
          \ && l:start <= l:child_start && l:child_end <= l:end
      call add(l:parents, l:tag)
    endif
  endfor

  call sort(l:parents, function('s:ctags_compare_parent_order'))

  return l:parents
endfunction


function! s:ctags_compare_parent_order(left, right) abort
  let l:left_start = get(a:left, 'line', 0)
  let l:right_start = get(a:right, 'line', 0)

  if l:left_start != l:right_start
    return l:left_start - l:right_start
  endif

  " For same start line, wider range is usually the outer container.
  return s:ctags_range_size(a:right) - s:ctags_range_size(a:left)
endfunction


function! s:join_numbers(numbers) abort
  return join(map(copy(a:numbers), 'string(v:val)'), ', ')
endfunction
function! s:first_matching_line(lines, pattern) abort
  for l:line in a:lines
    if l:line =~# a:pattern
      return l:line
    endif
  endfor

  return ''
endfunction

function! s:git_lines_ctags_debug(argv) abort
  call s:ctags_debug('git argv = ' . string(a:argv))

  let l:worktree = s:ctags_git_worktree()

  if empty(l:worktree)
    return []
  endif

  let l:cmd = ['git', '-C', l:worktree] + a:argv

  call s:ctags_debug('systemlist cmd = ' . string(l:cmd))

  let l:out = systemlist(l:cmd)

  call s:ctags_debug('systemlist shell_error = ' . string(v:shell_error))
  call s:ctags_debug('systemlist output lines = ' . string(len(l:out)))

  if !empty(l:out)
    call s:ctags_debug('systemlist output[0] = ' . string(get(l:out, 0, '')))
  endif

  if v:shell_error
    return []
  endif

  return l:out
endfunction
function! s:git_lines_ctags_debug(argv) abort
  call s:ctags_debug('git argv = ' . string(a:argv))

  let l:worktree = s:ctags_git_worktree()

  if empty(l:worktree)
    call s:ctags_debug('empty worktree; returning []')
    return []
  endif

  let l:escaped_args = map(copy(a:argv), 'shellescape(v:val)')
  let l:cmd = 'git -C ' . shellescape(l:worktree) . ' ' . join(l:escaped_args, ' ')

  call s:ctags_debug('systemlist cmd = ' . string(l:cmd))

  let l:out = systemlist(l:cmd)

  call s:ctags_debug('systemlist shell_error = ' . string(v:shell_error))
  call s:ctags_debug('systemlist output lines = ' . string(len(l:out)))

  if !empty(l:out)
    call s:ctags_debug('systemlist output[0] = ' . string(get(l:out, 0, '')))
  endif

  if v:shell_error
    call s:ctags_debug('git command failed; returning []')
    return []
  endif

  return l:out
endfunction
function! s:ctags_git_worktree() abort
  if exists('*FugitiveWorkTree')
    let l:worktree = FugitiveWorkTree()

    if !empty(l:worktree)
      call s:ctags_debug('FugitiveWorkTree() = ' . string(l:worktree))
      return l:worktree
    endif
  endif

  let l:cmd = 'git rev-parse --show-toplevel'
  let l:root = systemlist(l:cmd)

  call s:ctags_debug('fallback worktree cmd = ' . string(l:cmd))
  call s:ctags_debug('fallback worktree shell_error = ' . string(v:shell_error))
  call s:ctags_debug('fallback worktree output = ' . string(l:root))

  if v:shell_error || empty(l:root)
    call s:ctags_debug('could not determine git worktree')
    return ''
  endif

  return l:root[0]
endfunction


function! s:parse_ctags_tagfile_lines(lines) abort
  let l:tags = []

  for l:line in a:lines
    if empty(trim(l:line))
      continue
    endif

    " Skip pseudo-tags like !_TAG_FILE_FORMAT.
    if l:line =~# '^!'
      continue
    endif

    let l:tag = s:parse_ctags_tagfile_line(l:line)

    if !empty(l:tag)
      call add(l:tags, l:tag)
    endif
  endfor

  return l:tags
endfunction


function! s:parse_ctags_tagfile_line(line) abort
  let l:parts = split(a:line, "\t")

  " Normal tag format:
  " name<TAB>file<TAB>excmd;"<TAB>kind<TAB>field:value...
  if len(l:parts) < 4
    return {}
  endif

  let l:tag = {
        \ 'name': l:parts[0],
        \ 'line': 0,
        \ 'end': 0,
        \ 'kind': '',
        \ 'scope': '',
        \ }

  " Field 4 is often the kind, e.g. function, class, member.
  let l:maybe_kind = l:parts[3]

  if l:maybe_kind !~# ':'
    let l:tag.kind = l:maybe_kind
    let l:start_index = 4
  else
    let l:start_index = 3
  endif

  for l:i in range(l:start_index, len(l:parts) - 1)
    let l:field = l:parts[l:i]

    if l:field !~# ':'
      continue
    endif

    let l:key = matchstr(l:field, '^[^:]\+')
    let l:value = matchstr(l:field, '^[^:]\+:\zs.*')

    if l:key ==# 'line'
      let l:tag.line = str2nr(l:value)
    elseif l:key ==# 'end'
      let l:tag.end = str2nr(l:value)
    elseif l:key ==# 'kind'
      let l:tag.kind = l:value
    elseif l:key =~# '^\%(class\|struct\|namespace\|interface\|enum\|union\|module\|package\)$'
      let l:tag.scope = l:value
    elseif l:key ==# 'scope'
      let l:tag.scope = l:value
    endif
  endfor

  " Some tags may not have an end field. Keep them usable, but they will only
  " match changes on their declaration line.
  if get(l:tag, 'end', 0) <= 0
    let l:tag.end = get(l:tag, 'line', 0)
  endif

  if get(l:tag, 'line', 0) <= 0
    return {}
  endif

  return l:tag
endfunction

function! s:ctags_debug_relevant_tags(path, tags, changed_lines) abort
  call s:ctags_debug('--- relevant ctags for ' . a:path . ' ---')

  for l:tag in a:tags
    let l:name = get(l:tag, 'name', '')
    let l:kind = get(l:tag, 'kind', '')
    let l:line = get(l:tag, 'line', 0)
    let l:end = get(l:tag, 'end', l:line)
    let l:scope = get(l:tag, 'scope', '')

    let l:relevant = 0

    if l:name =~? 'JointQuantities\|isApprox'
      let l:relevant = 1
    endif

    for l:changed in a:changed_lines
      if l:line <= l:changed && l:changed <= l:end
        let l:relevant = 1
      endif
    endfor

    if l:relevant
      call s:ctags_debug(
            \ 'tag name=' . string(l:name) .
            \ ' kind=' . string(l:kind) .
            \ ' line=' . string(l:line) .
            \ ' end=' . string(l:end) .
            \ ' scope=' . string(l:scope)
            \ )
    endif
  endfor
endfunction

function! s:ctags_effective_kind(tag) abort
  let l:kind = tolower(get(a:tag, 'kind', ''))

  if !empty(l:kind)
    return l:kind
  endif

  let l:name = get(a:tag, 'name', '')
  let l:scope = get(a:tag, 'scope', '')
  let l:line = get(a:tag, 'line', 0)
  let l:end = get(a:tag, 'end', l:line)

  " Universal ctags sometimes emits C++ out-of-class method definitions with
  " an empty kind in normal tag output, but with class scope and a range.
  if !empty(l:scope) && l:end > l:line
    return 'function'
  endif

  if l:name =~# '::' && !empty(l:scope)
    return 'function'
  endif

  return ''
endfunction

function! s:ctags_debug_relevant_tags(path, tags, changed_lines) abort
  call s:ctags_debug('--- relevant ctags for ' . a:path . ' ---')

  for l:tag in a:tags
    let l:name = get(l:tag, 'name', '')
    let l:kind = get(l:tag, 'kind', '')
    let l:effective_kind = s:ctags_effective_kind(l:tag)
    let l:line = get(l:tag, 'line', 0)
    let l:end = get(l:tag, 'end', l:line)
    let l:scope = get(l:tag, 'scope', '')

    let l:relevant = 0

    if l:name =~? 'JointQuantities\|isApprox'
      let l:relevant = 1
    endif

    for l:changed in a:changed_lines
      if l:line <= l:changed && l:changed <= l:end
        let l:relevant = 1
      endif
    endfor

    if l:relevant
      call s:ctags_debug(
            \ 'tag name=' . string(l:name) .
            \ ' kind=' . string(l:kind) .
            \ ' effective_kind=' . string(l:effective_kind) .
            \ ' line=' . string(l:line) .
            \ ' end=' . string(l:end) .
            \ ' scope=' . string(l:scope)
            \ )
    endif
  endfor
endfunction
