  autocmd User FugitiveEditor call s:fugitive_commit_hook()
augroup END

function! s:fugitive_commit_hook() abort
  " Only operate on Git commit message buffers.
  if expand('%:t') !=# 'COMMIT_EDITMSG'
    return
  endif
  setlocal filetype=gitcommit
  let b:copilot_enabled = v:true

  " Add more procedures here.
  call s:prepend_jira_from_branch()
  call s:seed_copilot_commit_context()

  " Final cursor placement after all buffer mutations.
  call s:place_cursor_for_commit_message()

  startinsert
endfunction


" ============================================================================
" Procedure 1: prepend JIRA issue key from branch name
" ============================================================================

function! s:prepend_jira_from_branch() abort
  let l:branch = FugitiveHead()

  if empty(l:branch)
    return
  endif

  " Matches keys like ABC-123 or TEAM42-9.
  let l:jira = matchstr(l:branch, '\C[A-Z][A-Z0-9]*-\d\+')

  if empty(l:jira)
    return
  endif

  let l:first = getline(1)
  let l:prefix = '[' . l:jira . ']'

  " Do not duplicate the prefix.
  if stridx(l:first, l:prefix) == 0
    return
  endif

  " Also avoid duplicating if the user already wrote the bare key manually.
  if stridx(l:first, l:jira) == 0
    return
  endif

  " Do not rewrite special Git commit subjects.
  if l:first =~# '^\%(Merge \|fixup! \|squash! \)'
    return
  endif

  " Keep two spaces after the JIRA key, matching your current style.
  call setline(1, l:prefix . '  ' . l:first)
endfunction


" ============================================================================
" Procedure 2: seed Copilot context into the commit message buffer
" ============================================================================
function! s:seed_copilot_commit_context() abort
  " Avoid inserting the context twice.
  if exists('b:fugitive_commit_context_seeded')
    return
  endif

  if getline(2) =~# 'Copilot commit prompt'
    let b:fugitive_commit_context_seeded = 1
    return
  endif

  let l:c = s:commit_comment_char()

let l:context = [
      \ l:c . ' --- Copilot commit prompt ---',
      \ l:c . ' Task',
      \ l:c . ' - Generate a semantic Git commit message for the staged diff below.',
      \ l:c . ' - Focus on the functionality, API behavior, contract, workflow, or user-visible effect introduced by the change.',
      \ l:c . ' - Do not summarize the mechanical file edits, changed lines, renamed symbols, or internal state unless that is the actual behavior being changed.',
      \ l:c . ' - Prefer a functional-oriented message when the diff changes what the system does, what an API exposes, what a command supports, what data is accepted, or what output is produced.',
      \ l:c . ' - Use the semantic diff first to infer functionality, API behavior, contracts, workflows, and intent.',
      \ l:c . ' - Use a procedural message when the diff mainly changes how the system performs a task: strategy, orchestration, sequencing, state transitions, retries, caching, synchronization, validation flow, or fallback behavior.',
      \ l:c . ' - For procedural changes, describe the strategy explicitly with phrases like "using", "by", "through", or "via" when that improves precision.',
      \ l:c . ' - For declarative changes, describe the resulting capability or contract, not the implementation steps.',
      \ l:c . ' - If both apply, lead with the functional outcome and mention the procedural strategy only if it clarifies the change.',
      \ l:c,
      \ l:c . ' Message style',
      \ l:c . ' - Preserve any existing JIRA prefix on line 1, e.g. [ABC-123].',
      \ l:c . ' - The summary should say what capability, behavior, API, or workflow changed.',
      \ l:c . ' - Use imperative mood.',
      \ l:c . ' - Keep the subject under 72 characters when possible.',
      \ l:c . ' - Start the description after the type with a lowercase letter.',
      \ l:c . ' - Add a short body only when the strategy, behavior change, or migration risk needs clarification.',
      \ l:c,
      \ l:c . ' Avoid',
      \ l:c . ' - Avoid messages like "update files", "change logic", "fix code", "refactor stuff", or "modify state".',
      \ l:c . ' - Avoid naming files unless the file itself is the API, configuration, schema, or user-facing artifact.',
      \ l:c . ' - Avoid restating the diff. Infer the semantic intent from it.',
      \ l:c,
      \ ]

  " Optional project-specific context.
  for l:line in get(g:, 'fugitive_commit_extra_context', [])
    call add(l:context, l:c . ' - ' . l:line)
  endfor

  if !empty(get(g:, 'fugitive_commit_extra_context', []))
    call add(l:context, l:c)
  endif

  " This is the important part: add the actual staged diff.

  call extend(l:context, s:difftastic_staged_diff_context(l:c))

  call extend(l:context, s:ctags_diff_context(l:c))

  call extend(l:context, s:staged_diff_context(l:c))

  call extend(l:context, [
        \ l:c,
        \ l:c . ' --- End Copilot commit prompt ---',
        \ l:c,
        \ ])

  " Insert after line 1 so Copilot generates the real commit subject at the top.
  call append(1, l:context)

  let b:fugitive_commit_context_seeded = 1
endfunction


