function! s:place_cursor_for_commit_message() abort
  " Put cursor at the end of line 1.
  "
  " This works nicely with the JIRA prefix:
  "   [ABC-123]  |
  "
  " Copilot should then suggest the rest of the subject after the prefix.
  let l:first = getline(1)
  call cursor(1, strlen(l:first) + 1)
endfunction

